{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "server.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server.ts" },
    { "source": "/webhook/(.*)", "destination": "/server.ts" },
    { "source": "/(.*)", "destination": "/server.ts" }
  ]
}
